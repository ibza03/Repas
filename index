<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Menu Famille</title>
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-slate-50 font-sans antialiased pb-20">

    <div class="max-w-md mx-auto px-4 pt-12">
        <header class="mb-8 flex justify-between items-center">
            <h1 class="text-3xl font-black text-slate-800">Nos Menus 🍴</h1>
            <div id="status" class="w-3 h-3 bg-green-500 rounded-full shadow-lg"></div>
        </header>

        <div id="app" class="space-y-4">
            </div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getDatabase, ref, set, onValue } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-database.js";

        const firebaseConfig = { databaseURL: "https://meal-planner-famille-default-rtdb.europe-west1.firebasedatabase.app" };
        const app = initializeApp(firebaseConfig);
        const db = getDatabase(app);

        const jours = ["Lundi", "Mardi", "Mercredi", "Jeudi", "Vendredi", "Samedi", "Dimanche"];

        // Fonction pour créer l'interface
        function renderApp(data = {}) {
            const container = document.getElementById('app');
            container.innerHTML = '';

            jours.forEach(jour => {
                const menu = data[jour] || { midi: "A définir", soir: "A définir" };
                const card = document.createElement('div');
                card.className = "bg-white p-6 rounded-3xl shadow-sm border border-slate-100";
                card.innerHTML = `
                    <h2 class="font-bold text-slate-400 uppercase text-xs mb-4 tracking-widest">${jour}</h2>
                    <div class="space-y-4">
                        <div onclick="editPrompt('${jour}', 'midi', '${menu.midi}')" class="cursor-pointer active:scale-95 transition">
                            <span class="text-[10px] font-bold text-orange-500 uppercase">☀️ Midi</span>
                            <p class="text-slate-800 font-medium text-lg">${menu.midi}</p>
                        </div>
                        <div onclick="editPrompt('${jour}', 'soir', '${menu.soir}')" class="cursor-pointer active:scale-95 transition">
                            <span class="text-[10px] font-bold text-indigo-500 uppercase">🌙 Soir</span>
                            <p class="text-slate-800 font-medium text-lg">${menu.soir}</p>
                        </div>
                    </div>
                `;
                container.appendChild(card);
            });
        }

        // Fonction de modification
        window.editPrompt = (jour, moment, valeurActuelle) => {
            const nouveauPlat = prompt(`Changer le repas du ${jour} (${moment}) :`, valeurActuelle);
            if (nouveauPlat !== null) {
                set(ref(db, 'menus/' + jour + '/' + moment), nouveauPlat);
            }
        };

        // Écoute des changements en temps réel
        onValue(ref(db, 'menus/'), (snapshot) => {
            renderApp(snapshot.val() || {});
        });
    </script>
</body>
</html>
